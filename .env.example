# LLM backend: "groq" (cloud, default) or "ollama" (fully local)
LLM_BACKEND=groq

# Groq API key — required when LLM_BACKEND=groq. Get one at https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# Ollama (used when LLM_BACKEND=ollama, and always for embeddings)
# Defaults are fine for Docker Compose; override only if needed.
# OLLAMA_HOST=http://ollama:11434
# OLLAMA_MODEL=qwen3.5:4b
# EMBEDDING_MODEL=nomic-embed-text

# Adzuna Jobs API — optional, enables the Adzuna job source. Free tier at https://developer.adzuna.com
ADZUNA_APP_ID=your_adzuna_app_id
ADZUNA_API_KEY=your_adzuna_api_key

# Job site login credentials for autonomous application (can also be set per-persona)
JOB_EMAIL=your_email@example.com
JOB_PASSWORD=your_password
